{
  "env": {
    "OPENAI_API_KEY": "__OPENAI_KEY__",
    "DISCORD_BOT_TOKEN": "",
    "BRAVE_API_KEY": ""
  },
  "models": {
    "providers": {
      "openai": {
        "apiKey": "__OPENAI_KEY__"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-4o-mini"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "subagents": {
        "maxConcurrent": 4,
        "archiveAfterMinutes": 60,
        "model": "openai/gpt-4o-mini"
      }
    },
    "list": [
      {
        "id": "manager",
        "default": true,
        "workspace": "/home/ubuntu/openclaw-workspaces/manager",
        "model": {
          "primary": "openai/gpt-4o"
        },
        "subagents": {
          "allowAgents": [
            "server-dev",
            "frontend-dev",
            "uiux-designer",
            "researcher",
            "design-critic"
          ],
          "model": "openai/gpt-4o-mini"
        }
      },
      {
        "id": "server-dev",
        "workspace": "/home/ubuntu/openclaw-workspaces/server-dev",
        "model": {
          "primary": "openai/gpt-4o-mini"
        }
      },
      {
        "id": "frontend-dev",
        "workspace": "/home/ubuntu/openclaw-workspaces/frontend-dev",
        "model": {
          "primary": "openai/gpt-4o-mini"
        }
      },
      {
        "id": "uiux-designer",
        "workspace": "/home/ubuntu/openclaw-workspaces/uiux-designer",
        "model": {
          "primary": "openai/gpt-4o-mini"
        }
      },
      {
        "id": "researcher",
        "workspace": "/home/ubuntu/openclaw-workspaces/researcher",
        "model": {
          "primary": "openai/gpt-4o-mini"
        }
      },
      {
        "id": "design-critic",
        "workspace": "/home/ubuntu/openclaw-workspaces/design-critic",
        "model": {
          "primary": "openai/gpt-4o-mini"
        }
      }
    ]
  },
  "tools": {
    "agentToAgent": {
      "enabled": true
    },
    "exec": {
      "security": "full",
      "ask": "off"
    }
  },
  "messages": {
    "ackReactionScope": "all"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true
  },
  "channels": {
    "discord": {
      "enabled": false,
      "token": "",
      "groupPolicy": "allowlist",
      "dmPolicy": "allowlist",
      "allowFrom": [],
      "guilds": {}
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "open"
    }
  },
  "plugins": {
    "entries": {
      "discord": {
        "enabled": false
      }
    }
  }
}
